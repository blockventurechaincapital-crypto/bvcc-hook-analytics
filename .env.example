# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Arbitrum RPCs (comma-separated, tried in order) ─────────────────────────
ARB_RPCS=https://arb-one.api.pocket.network,https://arbitrum.meowrpc.com,https://public-arb-mainnet.fastnode.io,https://arbitrum-one.public.blastapi.io

# ─── BSC RPCs ─────────────────────────────────────────────────────────────────
BSC_RPCS=https://bsc.api.pocket.network,https://bsc.meowrpc.com,https://bsc.publicnode.com,https://bsc-dataseed1.ninicoin.io

# ─── Base RPCs ────────────────────────────────────────────────────────────────
BASE_RPCS=https://rpc.ankr.com/base,https://mainnet.base.org,https://base.drpc.org,https://base-rpc.publicnode.com

# ─── Ethereum RPCs ────────────────────────────────────────────────────────────
ETH_RPCS=https://ethereum-rpc.publicnode.com,https://eth.llamarpc.com,https://ethereum-public.nodies.app,https://eth-mainnet.public.blastapi.io

# ─── Server RPCs (single, used for TVL extsload calls) ───────────────────────
# Replace with a paid RPC (Alchemy, Infura, QuickNode) for better reliability
ARB_RPC=https://arbitrum-one.public.blastapi.io
BSC_RPC=https://bsc.publicnode.com
BASE_RPC=https://base-rpc.publicnode.com
ETH_RPC=https://ethereum-rpc.publicnode.com

# ─── Server port ──────────────────────────────────────────────────────────────
PORT=3000
